# ───────────────────────────────────────────────────────────────
# InnerView configuration
# ───────────────────────────────────────────────────────────────

# Your publishable Pollinations App Key (pk_...). Used for BYOP so users
# authorize YOUR app on the consent screen and pay with their own pollen.
# Create one at https://enter.pollinations.ai -> "Create New App Key"
# and add this app's URL (e.g. http://localhost:3000/onboarding/callback)
# as a Redirect URI.
NEXT_PUBLIC_POLLINATIONS_APP_KEY=pk_replace_with_your_app_key

# BYOP consent defaults
NEXT_PUBLIC_BYOP_SCOPE=usage
NEXT_PUBLIC_BYOP_BUDGET=10
NEXT_PUBLIC_BYOP_EXPIRY_DAYS=7

# ───────────────────────────────────────────────────────────────
# Supabase — account & encrypted journal storage (Phase 0)
# Create a project at https://supabase.com → Project Settings → API.
# Both values are the *public* (anon) surface, safe to ship client-side.
# Security comes from Row-Level Security + end-to-end encryption:
# InnerView stores ONLY ciphertext in Supabase; the server can never
# read your journal. See supabase/SETUP.md and supabase/schema.sql.
# ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY

